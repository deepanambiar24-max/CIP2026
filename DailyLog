def journal():
    """
    Journal - here one can log daily entries, like a diary. 
    Created this function to log user entries, view them (all/single - by searching using a keyword or date). 
    Gives the user the option to go back to main menu as well. 
    There are statements to verify whether user input is a number. 
    I also used the .lower() method in the keyword search so that irrespective of the case the user enters the keyword in, the keyword can be searched and that particular entry can be shown.
    """
       
    while True:
        try:
            y = int (input("1. New entry \n2. View entries \n3. Go back to main menu \n"))
        except ValueError:
            print("Please enter a number between 1 and 3.\n")
            continue
        if 1<= y <=3:
            if y == 1:
                now = datetime.now()
                date_today = now.strftime("%d/%m/%Y")
                now_time = now.strftime("%H:%M")
                    
                value_inp = input()
                with open("journal.txt", "a") as file:
                    file.write(f"{date_today}|{now_time}|{value_inp}\n")
    
            elif y == 2:
                
                
                view_entry = input("Would you like to view all entries or single entry? ")
                if view_entry.lower() == "all":
                    with open("journal.txt", "r") as file:
                        entries = file.readlines()
                        if len(entries) == 0:
                            print("No journal entries found.\n")
                        else:
                            for line in entries:
                                parts = line.strip().split("|")
                                print("-" * 40)
                                print(f"Date: {parts[0]}")
                                print(f"Time: {parts[1]}")
                                print(f"Entry: {parts[2]}")
                                print()
                            
                
                elif view_entry.lower() == "single":
                    search_type = input("Would you like to search by keyword or date? ")
                    if search_type.lower() == "keyword":
                        user_keyword = input("Please enter keyword: ")
                        found = False
                        with open("journal.txt", "r") as file:
                            for line in file:
                                if user_keyword.lower() in line.lower():
                                    parts = line.strip().split("|")
                                    print("-" * 40)
                                    print(f"Date: {parts[0]}")
                                    print(f"Time: {parts[1]}")
                                    print(f"Entry: {parts[2]}")
                                    print("-" * 40)
                                    print()
                                    found = True
                        
                        if not found:
                            print ("Not in log")        
                                        
                                
                    elif search_type.lower() == "date":
                        user_date = input("Please enter date: ")
                        found = False
                        with open ("journal.txt", "r") as file:
                            for line in file:
                                if user_date in line:
                                    parts = line.strip().split("|")
                                    print("-" * 40)
                                    print(f"Date: {parts[0]}")
                                    print(f"Time: {parts[1]}")
                                    print(f"Entry: {parts[2]}")
                                    print("-" * 40)
                                    print()
                                    found = True
                        if not found:
                            print("Not in log")        
                    else:
                        print("Please enter keyword or date.\n")
                else:
                    print("Please enter all or single.\n")
                    
            elif y == 3:
                return
            

        else:
            print("Please enter a number between 1 and 3.\n")
            continue


def tasks():
    """
    Tasks - one can add tasks for the day, view them, and by end of the day, mark them done.
    """
    while True:
        try:
            x = int(input("Would you like to:\n 1. Add a task \n 2. View all tasks\n 3. Mark task as completed \n 4. Return to main menu\n"))
        except ValueError:
            print("Please enter a number between 1 and 4.\n")
            continue
        if 1<=x<=4:
            if x == 1:
                user_task = input("Please enter your task: ")
                with open("tasks.txt","a") as file:
                    file.write("TODO|" + user_task + "\n")
                
            elif x == 2:
                
                with open("tasks.txt","r") as file:
                    entries = file.readlines()
                    if len(entries) == 0:
                            print("No tasks found.\n")
                    count =1
                    for line in entries:
                        status, task = line.strip().split("|")
                        print(f"{count}. [{status}]{task}")
                        count += 1
            elif x == 3:
                count = 1
                with open("tasks.txt","r") as file:
                    for line in file:
                        print(f"{count}.{line.strip()}")
                        count += 1
                try:
                    task_number = int(input("Which task should be marked as completed?"))
                except ValueError:
                    print("Please enter a valid task number.\n")
                    continue
                
                with open("tasks.txt","r") as file:
                    tasks = file.readlines()
                    if 1<= task_number <= len(tasks):
                        tasks[task_number-1] = tasks[task_number-1].replace("TODO","DONE")
                    else:
                        print("Invalid task number.")
                        continue
                    #print(tasks)

                with open("tasks.txt","w") as file:
                    file.writelines(tasks)
            elif x == 4:
                return
            
            
        else:
            print("Please enter a number between 1 and 4.\n")

def meal_planner():
    """
    Meal Planner - User can enter their mela plan for the day or the coming days. They can view them as well.
    """
    while True:
        try:    
            user_option = int(input ("What would you like to do?\n 1. Add a meal plan \n 2. View meal plan \n 3. Return to main menu \n"))
        
        except ValueError:
            print("Please enter a number between 1 and 3.\n")
            continue
        
        if user_option == 1:
            user_date = input("For which date would you like to add meal plan? ")
            breakfast = input("What would like for breakfast? ")
            lunch = input("What would you like for lunch? ")
            dinner = input("What would you like for dinner? ")
            with open ("meals.txt", "a") as file:
                file.write(f"{user_date}|{breakfast}|{lunch}|{dinner}\n")
            

        elif user_option == 2:
            with open ("meals.txt","r") as file:
                entries = file.readlines()
                if len(entries) == 0:
                            print("No meal plans found.\n")
                for line in entries:
                    parts = line.strip().split("|")
                    print("-" * 40)
                    print(f"Date: {parts[0]}")
                    print(f"Breakfast: {parts[1]}")
                    print(f"Lunch: {parts[2]}")
                    print(f"Dinner: {parts[3]}")
                    print()
                        
        
        elif user_option == 3:
            return
        else:
            print ("Please enter a number between 1 and 3.\n")

