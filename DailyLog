def mood_tracker():
    """
    Mood Tracker - user can log the mood for the day. They can also view mood history and 
    see how many days they were happy/anxious/excited and so on.
    """
    while True:
        try:    
            user_input = int(input("Would you like to:\n 1. Log mood \n 2. View Mood History Summary \n 3. Return to main menu\n"))
        except ValueError:
            print("Please enter a number between 1 and 3.\n")
            continue
        mood = ["Happy","Excited","Calm","Productive","Motivated","Tired","Stressed","Sad","Anxious","Angry"]
        if 1<= user_input <=3:
                
            if user_input == 1:
                try:
                        
                    user_mood = int(input("How are you feeling today? \n1. Happy \n2.Excited \n3.Calm \n4.Productive \n5.Motivated \n6.Tired \n7.Stressed \n8.Sad \n9.Anxious \n10.Angry\n"))
                    if 1<= user_mood <= 10:
                            
                        selected_mood = mood[user_mood - 1]
                        now = datetime.now()
                        date_today = now.strftime("%d/%m/%Y")
                        with open ("mood_tracker.txt","a") as file:
                            file.write(f"{date_today}|{selected_mood}\n")
                    else:
                        print("Please choose a number between 1 and 10.\n")
                        continue
                except ValueError:
                    print("Please enter a number.\n")
                    continue

            elif user_input == 2:
                moods_dict = {}
                with open ("mood_tracker.txt","r") as file:
                    entries = file.readlines()
                    if len(entries) == 0:
                            print("No entries found.\n")
                    for line in entries:
                        parts = line.strip().split("|")
                        if parts[1] not in moods_dict:
                            moods_dict[parts[1]] = 1
                        else:
                            moods_dict[parts[1]] += 1
                for mood,count in moods_dict.items():
                    print(f"{mood}: {count} days\n")    
            

            
            elif user_input == 3:
                return
        else:
            print("Please enter a number between 1 and 3.\n")
            continue    

if __name__ == "__main__":
    main()
